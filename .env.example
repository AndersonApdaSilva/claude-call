# claude-call — config (all optional, sensible defaults). Copy to .env and tweak.

# --- Language & voice ---
CALL_LANG=en                       # en, pt, es, fr, de, it, ja...
# CALL_NAME=Claudinho              # nome/persona (aparece no painel e na saudacao)
# CALL_VOICE=en-US-AndrewNeural    # edge voice, or a voice id for a premium provider below
# CALL_VOICE_RATE=+0%              # edge only
# CALL_GREETING=Hey, I'm here. What's up?

# --- Premium voice (optional, pay-as-you-go — bring your own key) ---
# CALL_TTS=edge                    # edge (free) | elevenlabs | cartesia | openai | rime | deepgram
# CALL_TTS_API_KEY=                # your provider key (or set the provider's own env var, e.g. ELEVENLABS_API_KEY)
# CALL_TTS_MODEL=                  # optional model override (e.g. eleven_turbo_v2_5, sonic-2, gpt-4o-mini-tts)
# For premium, also set CALL_VOICE to a voice id from that provider.

# --- Brain (your Claude Code) ---
# COST: claude-call runs `claude -p` (headless). As of 2026-06-15, Anthropic bills headless/
# Agent-SDK usage from a separate monthly agent credit ($20 Pro / $100 Max5x / $200 Max20x) at
# API rates — NOT your flat subscription; when it runs out, calls stop. See README "Cost & billing".
# Cheaper: CALL_MODEL=haiku and CALL_CONTINUE=0 (fresh session = far fewer input tokens).
# Prefer direct pay-as-you-go API billing? Uncomment and set your key — `claude -p` will use it:
# ANTHROPIC_API_KEY=
# CALL_MODEL=                      # empty = your Claude Code default. e.g. opus / sonnet / haiku
# Hands-free needs no permission prompts. SECURITY: this lets the agent run tools/bash
# without asking. Read the README. Use CALL_PERMISSION=--permission-mode default to be asked
# (but voice will hang on prompts).
# CALL_PERMISSION=--dangerously-skip-permissions

# --- Session continuity (the whole point) ---
CALL_CONTINUE=1                    # 1 = resume your most recent Claude Code session in CALL_CWD
# CALL_SESSION_ID=                 # pin a specific session id
# CALL_CWD=                        # which project's session to resume (default: where you run it)

# --- Activation ---
# CALL_WAKE=                       # empty = open mic (call mode). Set e.g. "claude" to require a wake word.
# CALL_ACTIVE_WINDOW=25
# CALL_IDLE_TIMEOUT=1800           # seconds of silence before the call auto-ends (default 30 min). 0/off = never.

# --- Feedback visual ---
# CALL_UI=1                        # 1 = painel ao vivo no terminal (ouvido/fazendo/resposta)
#   + janela "Claude Code ao vivo" sob comando de voz ("mostra a tela", "abre o claude").
#   Auto-desliga sem TTY (ex.: rodando em background). 0 = sem painel.

# --- Echo (speaker without headphones) ---
CALL_ECHO_GATE=1                   # 1 = mute mic while it speaks (use on speakers). 0 = barge-in (use headphones).
# CALL_AEC=0                       # 1 = macOS hardware AEC (barge-in without headphones). Needs ./build.sh + mic permission.

# --- STT provider ---
# CALL_STT=local                   # local (whisper.cpp, free) | elevenlabs | groq | openai
#   local      = whisper.cpp on-device, free. 'small' model is weak — bump CALL_WHISPER_MODEL
#                to a bigger one (medium / large-v3-turbo) for much better quality, still free.
#   elevenlabs = Scribe API (scribe_v1). Great multilingual/PT. ~$0.40/hr.
#   groq       = whisper-large-v3-turbo. Cheapest hosted (~$0.04/hr), fast. Needs a free Groq key.
#   openai     = gpt-4o-mini-transcribe (or whisper-1). ~$0.18/hr.
# CALL_STT_API_KEY=                # or set the provider's env var (ELEVENLABS_API_KEY / GROQ_API_KEY / OPENAI_API_KEY)
# CALL_STT_MODEL=                  # override default model for the chosen provider

# --- STT local (whisper.cpp), used when CALL_STT=local ---
# CALL_WHISPER_MODEL=~/.cache/whisper/ggml-small.bin
# CALL_WHISPER_PORT=8099
# CALL_WHISPER_SERVER=1            # 0 = use whisper-cli per utterance (slower) instead of the resident server
